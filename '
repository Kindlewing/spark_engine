#include "renderer.h"
#include "glm/fwd.hpp"

using glm::vec2;

void Renderer2D::render(Sprite* sprite, glm::vec3 pos, glm::vec2 size);
clearColor();
this->shader.use();
glm::mat4 model = glm::mat4(1.0f);
}

void Renderer2D::clearColor() {
	glClearColor(0.2f, 0.3f, 0.3f, 1.0f);
	glClear(GL_COLOR_BUFFER_BIT);
}
